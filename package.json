{
  "name": "omocs",
  "version": "1.0.0",
  "description": "OMOC Suites — CLI toolkit for OpenCode power users",
  "type": "module",
  "bin": {
    "omocs": "./bin/omocs.ts"
  },
  "scripts": {
    "start": "bun run bin/omocs.ts",
    "dev": "bun run --watch bin/omocs.ts",
    "build": "bun build bin/omocs.ts --outdir dist --target bun"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.0",
    "cli-table3": "^0.6.0",
    "boxen": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "author": "TheFahmi",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheFahmi/omocs.git"
  },
  "keywords": ["opencode", "cli", "developer-tools", "ai", "coding-assistant"]
}
