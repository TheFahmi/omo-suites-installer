{
  "name": "omocs",
  "version": "1.2.0",
  "description": "OMO Suites — OpenCode plugin + CLI toolkit. Multi-model orchestration, profiles, agent routing, MCP/LSP management.",
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/plugin.js"
    }
  },
  "bin": {
    "omocs": "./bin/omocs.ts"
  },
  "scripts": {
    "start": "bun run bin/omocs.ts",
    "dev": "bun run --watch bin/omocs.ts",
    "build": "bun build src/plugin.ts --outdir dist --target bun --format esm",
    "build:cli": "bun build bin/omocs.ts --outdir dist/cli --target bun"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.20",
    "boxen": "^8.0.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.0",
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "author": "TheFahmi",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheFahmi/omocs.git"
  },
  "keywords": ["opencode", "cli", "developer-tools", "ai", "coding-assistant", "plugin", "profiles", "mcp", "lsp", "agent-routing"]
}
